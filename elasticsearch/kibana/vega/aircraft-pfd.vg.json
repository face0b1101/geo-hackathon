{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "description": "Aircraft Primary Flight Display — airspeed, altitude, heading, vertical speed gauges with live ADS-B telemetry",
  "width": 900,
  "height": 500,
  "padding": 0,
  "autosize": "none",
  "background": "#1D1E24",

  "data": [
    {
      "name": "raw",
      "url": {
        "%context%": true,
        "%timefield%": "@timestamp",
        "index": "demos-aircraft-adsb",
        "body": {
          "size": 1,
          "sort": [{"@timestamp": "desc"}]
        }
      },
      "format": {"property": "hits.hits"}
    },
    {
      "name": "aircraft",
      "source": "raw",
      "transform": [
        {"type": "formula", "as": "callsign",       "expr": "datum._source.callsign || 'N/A'"},
        {"type": "formula", "as": "icao24",          "expr": "datum._source.icao24 || 'N/A'"},
        {"type": "formula", "as": "origin_country",  "expr": "datum._source.origin_country || ''"},
        {"type": "formula", "as": "velocity",        "expr": "datum._source.velocity != null ? datum._source.velocity : 0"},
        {"type": "formula", "as": "true_track",      "expr": "datum._source.true_track != null ? datum._source.true_track : 0"},
        {"type": "formula", "as": "baro_altitude",   "expr": "datum._source.baro_altitude != null ? datum._source.baro_altitude : 0"},
        {"type": "formula", "as": "geo_altitude",    "expr": "datum._source.geo_altitude != null ? datum._source.geo_altitude : 0"},
        {"type": "formula", "as": "vertical_rate",   "expr": "datum._source.vertical_rate != null ? datum._source.vertical_rate : 0"},
        {"type": "formula", "as": "squawk",          "expr": "datum._source.squawk || '----'"},
        {"type": "formula", "as": "on_ground",       "expr": "datum._source.on_ground === true"},
        {"type": "formula", "as": "airport_name",    "expr": "datum._source.airport ? (datum._source.airport.iata_code || datum._source.airport.name_en || '') : ''"},
        {"type": "formula", "as": "airport_activity", "expr": "datum._source.airport ? (datum._source.airport.activity || '') : ''"},
        {"type": "formula", "as": "velocity_kts",    "expr": "datum.velocity * 1.94384"}
      ]
    },
    {
      "name": "speed_ticks",
      "values": [0, 50, 100, 150, 200, 250, 300]
    },
    {
      "name": "alt_ticks",
      "values": [0, 2000, 4000, 6000, 8000, 10000, 12000]
    },
    {
      "name": "compass_ticks",
      "values": [
        {"deg": 0,   "label": "N"},
        {"deg": 30,  "label": ""},
        {"deg": 60,  "label": ""},
        {"deg": 90,  "label": "E"},
        {"deg": 120, "label": ""},
        {"deg": 150, "label": ""},
        {"deg": 180, "label": "S"},
        {"deg": 210, "label": ""},
        {"deg": 240, "label": ""},
        {"deg": 270, "label": "W"},
        {"deg": 300, "label": ""},
        {"deg": 330, "label": ""}
      ]
    },
    {
      "name": "vsi_ticks",
      "values": [-20, -15, -10, -5, 0, 5, 10, 15, 20]
    }
  ],

  "signals": [
    {"name": "vel",       "update": "data('aircraft')[0] ? data('aircraft')[0].velocity : 0"},
    {"name": "velKts",    "update": "data('aircraft')[0] ? data('aircraft')[0].velocity_kts : 0"},
    {"name": "trk",       "update": "data('aircraft')[0] ? data('aircraft')[0].true_track : 0"},
    {"name": "baroAlt",   "update": "data('aircraft')[0] ? data('aircraft')[0].baro_altitude : 0"},
    {"name": "geoAlt",    "update": "data('aircraft')[0] ? data('aircraft')[0].geo_altitude : 0"},
    {"name": "vRate",     "update": "data('aircraft')[0] ? data('aircraft')[0].vertical_rate : 0"},
    {"name": "sqk",       "update": "data('aircraft')[0] ? data('aircraft')[0].squawk : '----'"},
    {"name": "cs",        "update": "data('aircraft')[0] ? data('aircraft')[0].callsign : 'N/A'"},
    {"name": "icao",      "update": "data('aircraft')[0] ? data('aircraft')[0].icao24 : 'N/A'"},
    {"name": "origin",    "update": "data('aircraft')[0] ? data('aircraft')[0].origin_country : ''"},
    {"name": "onGnd",     "update": "data('aircraft')[0] ? data('aircraft')[0].on_ground : false"},
    {"name": "aptName",   "update": "data('aircraft')[0] ? data('aircraft')[0].airport_name : ''"},
    {"name": "aptAct",    "update": "data('aircraft')[0] ? data('aircraft')[0].airport_activity : ''"},

    {"name": "gaugeR", "value": 80},
    {"name": "arcStart", "value": -2.356},
    {"name": "arcEnd",   "value": 2.356},
    {"name": "arcRange", "update": "arcEnd - arcStart"},

    {"name": "spdAngle", "update": "arcStart + (min(vel, 300) / 300) * arcRange"},
    {"name": "altAngle", "update": "arcStart + (min(baroAlt, 12000) / 12000) * arcRange"},

    {"name": "sqkColor", "update": "sqk == '7500' ? '#E7664C' : sqk == '7600' ? '#DA8B45' : sqk == '7700' ? '#E7664C' : '#DFE5EF'"},
    {"name": "sqkBg",    "update": "sqk == '7500' || sqk == '7700' ? '#4D2020' : sqk == '7600' ? '#4D3A20' : '#25262E'"},

    {"name": "gndColor", "update": "onGnd ? '#54B399' : '#6092C0'"},
    {"name": "gndLabel", "update": "onGnd ? 'ON GROUND' : 'AIRBORNE'"}
  ],

  "marks": [
    {
      "type": "group",
      "name": "statusBar",
      "encode": {
        "enter": {
          "x": {"value": 0},
          "y": {"value": 0},
          "width": {"signal": "width"},
          "height": {"value": 60},
          "fill": {"value": "#25262E"}
        }
      },
      "marks": [
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 20}, "y": {"value": 28},
              "text": {"signal": "cs"},
              "fontSize": {"value": 24}, "fontWeight": {"value": "bold"},
              "fill": {"value": "#DFE5EF"}, "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 20}, "y": {"value": 48},
              "text": {"signal": "'ICAO ' + icao"},
              "fontSize": {"value": 12},
              "fill": {"value": "#69707D"}, "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "rect",
          "encode": {
            "update": {
              "x": {"value": 280}, "y": {"value": 8},
              "width": {"value": 120}, "height": {"value": 44},
              "fill": {"signal": "sqkBg"},
              "cornerRadius": {"value": 4},
              "stroke": {"signal": "sqkColor"},
              "strokeWidth": {"value": 1}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 340}, "y": {"value": 24},
              "text": {"value": "SQUAWK"},
              "fontSize": {"value": 10}, "align": {"value": "center"},
              "fill": {"value": "#69707D"}, "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 340}, "y": {"value": 44},
              "text": {"signal": "sqk"},
              "fontSize": {"value": 20}, "fontWeight": {"value": "bold"},
              "align": {"value": "center"},
              "fill": {"signal": "sqkColor"}, "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 480}, "y": {"value": 28},
              "text": {"signal": "origin"},
              "fontSize": {"value": 14},
              "fill": {"value": "#98A2B3"}, "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "rect",
          "encode": {
            "update": {
              "x": {"value": 720}, "y": {"value": 12},
              "width": {"value": 160}, "height": {"value": 36},
              "fill": {"value": "#25262E"},
              "cornerRadius": {"value": 4},
              "stroke": {"signal": "gndColor"},
              "strokeWidth": {"value": 1}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 800}, "y": {"value": 36},
              "text": {"signal": "gndLabel"},
              "fontSize": {"value": 14}, "fontWeight": {"value": "bold"},
              "align": {"value": "center"},
              "fill": {"signal": "gndColor"}, "font": {"value": "monospace"}
            }
          }
        }
      ]
    },

    {
      "type": "group",
      "name": "airspeedGauge",
      "encode": {
        "enter": {
          "x": {"value": 110},
          "y": {"value": 260},
          "width": {"value": 200},
          "height": {"value": 200}
        }
      },
      "marks": [
        {
          "type": "arc",
          "encode": {
            "update": {
              "x": {"value": 0}, "y": {"value": 0},
              "startAngle": {"signal": "arcStart"},
              "endAngle": {"signal": "arcEnd"},
              "innerRadius": {"signal": "gaugeR - 12"},
              "outerRadius": {"signal": "gaugeR"},
              "fill": {"value": "#343741"}
            }
          }
        },
        {
          "type": "arc",
          "encode": {
            "update": {
              "x": {"value": 0}, "y": {"value": 0},
              "startAngle": {"signal": "arcStart"},
              "endAngle": {"signal": "spdAngle"},
              "innerRadius": {"signal": "gaugeR - 12"},
              "outerRadius": {"signal": "gaugeR"},
              "fill": {"signal": "vel < 100 ? '#54B399' : vel < 200 ? '#D6BF57' : '#E7664C'"}
            }
          }
        },
        {
          "type": "rule",
          "encode": {
            "update": {
              "x": {"signal": "(gaugeR - 24) * cos(spdAngle - PI/2)"},
              "y": {"signal": "(gaugeR - 24) * sin(spdAngle - PI/2)"},
              "x2": {"signal": "(gaugeR + 4) * cos(spdAngle - PI/2)"},
              "y2": {"signal": "(gaugeR + 4) * sin(spdAngle - PI/2)"},
              "stroke": {"value": "#DFE5EF"},
              "strokeWidth": {"value": 2}
            }
          }
        },
        {
          "type": "text",
          "from": {"data": "speed_ticks"},
          "encode": {
            "update": {
              "x": {"signal": "(gaugeR + 16) * cos(arcStart + (datum.data / 300) * arcRange - PI/2)"},
              "y": {"signal": "(gaugeR + 16) * sin(arcStart + (datum.data / 300) * arcRange - PI/2)"},
              "text": {"signal": "datum.data"},
              "fontSize": {"value": 9},
              "align": {"value": "center"}, "baseline": {"value": "middle"},
              "fill": {"value": "#69707D"}, "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 0}, "y": {"value": -10},
              "text": {"signal": "format(vel, '.0f')"},
              "fontSize": {"value": 28}, "fontWeight": {"value": "bold"},
              "align": {"value": "center"}, "baseline": {"value": "middle"},
              "fill": {"value": "#DFE5EF"}, "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 0}, "y": {"value": 14},
              "text": {"value": "m/s"},
              "fontSize": {"value": 11},
              "align": {"value": "center"}, "baseline": {"value": "middle"},
              "fill": {"value": "#69707D"}, "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 0}, "y": {"value": 34},
              "text": {"signal": "format(velKts, '.0f') + ' kts'"},
              "fontSize": {"value": 11},
              "align": {"value": "center"}, "baseline": {"value": "middle"},
              "fill": {"value": "#69707D"}, "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 0}, "y": {"value": 60},
              "text": {"value": "AIRSPEED"},
              "fontSize": {"value": 11}, "fontWeight": {"value": "bold"},
              "align": {"value": "center"}, "baseline": {"value": "middle"},
              "fill": {"value": "#98A2B3"}, "font": {"value": "monospace"}
            }
          }
        }
      ]
    },

    {
      "type": "group",
      "name": "altitudeGauge",
      "encode": {
        "enter": {
          "x": {"value": 330},
          "y": {"value": 260},
          "width": {"value": 200},
          "height": {"value": 200}
        }
      },
      "marks": [
        {
          "type": "arc",
          "encode": {
            "update": {
              "x": {"value": 0}, "y": {"value": 0},
              "startAngle": {"signal": "arcStart"},
              "endAngle": {"signal": "arcEnd"},
              "innerRadius": {"signal": "gaugeR - 12"},
              "outerRadius": {"signal": "gaugeR"},
              "fill": {"value": "#343741"}
            }
          }
        },
        {
          "type": "arc",
          "encode": {
            "update": {
              "x": {"value": 0}, "y": {"value": 0},
              "startAngle": {"signal": "arcStart"},
              "endAngle": {"signal": "altAngle"},
              "innerRadius": {"signal": "gaugeR - 12"},
              "outerRadius": {"signal": "gaugeR"},
              "fill": {"signal": "baroAlt < 3000 ? '#54B399' : baroAlt < 9000 ? '#6092C0' : '#D6BF57'"}
            }
          }
        },
        {
          "type": "rule",
          "encode": {
            "update": {
              "x": {"signal": "(gaugeR - 24) * cos(altAngle - PI/2)"},
              "y": {"signal": "(gaugeR - 24) * sin(altAngle - PI/2)"},
              "x2": {"signal": "(gaugeR + 4) * cos(altAngle - PI/2)"},
              "y2": {"signal": "(gaugeR + 4) * sin(altAngle - PI/2)"},
              "stroke": {"value": "#DFE5EF"},
              "strokeWidth": {"value": 2}
            }
          }
        },
        {
          "type": "text",
          "from": {"data": "alt_ticks"},
          "encode": {
            "update": {
              "x": {"signal": "(gaugeR + 16) * cos(arcStart + (datum.data / 12000) * arcRange - PI/2)"},
              "y": {"signal": "(gaugeR + 16) * sin(arcStart + (datum.data / 12000) * arcRange - PI/2)"},
              "text": {"signal": "datum.data >= 1000 ? format(datum.data / 1000, '.0f') + 'k' : format(datum.data, '.0f')"},
              "fontSize": {"value": 9},
              "align": {"value": "center"}, "baseline": {"value": "middle"},
              "fill": {"value": "#69707D"}, "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 0}, "y": {"value": -16},
              "text": {"signal": "format(baroAlt, ',.0f')"},
              "fontSize": {"value": 24}, "fontWeight": {"value": "bold"},
              "align": {"value": "center"}, "baseline": {"value": "middle"},
              "fill": {"value": "#DFE5EF"}, "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 0}, "y": {"value": 4},
              "text": {"value": "BARO m"},
              "fontSize": {"value": 10},
              "align": {"value": "center"}, "baseline": {"value": "middle"},
              "fill": {"value": "#69707D"}, "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 0}, "y": {"value": 24},
              "text": {"signal": "'GEO ' + format(geoAlt, ',.0f') + ' m'"},
              "fontSize": {"value": 10},
              "align": {"value": "center"}, "baseline": {"value": "middle"},
              "fill": {"value": "#69707D"}, "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 0}, "y": {"value": 60},
              "text": {"value": "ALTITUDE"},
              "fontSize": {"value": 11}, "fontWeight": {"value": "bold"},
              "align": {"value": "center"}, "baseline": {"value": "middle"},
              "fill": {"value": "#98A2B3"}, "font": {"value": "monospace"}
            }
          }
        }
      ]
    },

    {
      "type": "group",
      "name": "headingCompass",
      "encode": {
        "enter": {
          "x": {"value": 560},
          "y": {"value": 260},
          "width": {"value": 200},
          "height": {"value": 200}
        }
      },
      "marks": [
        {
          "type": "arc",
          "encode": {
            "update": {
              "x": {"value": 0}, "y": {"value": 0},
              "startAngle": {"value": 0},
              "endAngle": {"signal": "2 * PI"},
              "innerRadius": {"signal": "gaugeR - 2"},
              "outerRadius": {"signal": "gaugeR"},
              "fill": {"value": "#343741"}
            }
          }
        },
        {
          "type": "text",
          "from": {"data": "compass_ticks"},
          "encode": {
            "update": {
              "x": {"signal": "(gaugeR - 14) * cos((datum.deg - trk) * PI / 180 - PI/2)"},
              "y": {"signal": "(gaugeR - 14) * sin((datum.deg - trk) * PI / 180 - PI/2)"},
              "text": {"signal": "datum.label !== '' ? datum.label : format(datum.deg, '.0f')"},
              "fontSize": {"signal": "datum.label !== '' ? 14 : 9"},
              "fontWeight": {"signal": "datum.label !== '' ? 'bold' : 'normal'"},
              "align": {"value": "center"}, "baseline": {"value": "middle"},
              "fill": {"signal": "datum.label === 'N' ? '#E7664C' : datum.label !== '' ? '#DFE5EF' : '#69707D'"},
              "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "rule",
          "from": {"data": "compass_ticks"},
          "encode": {
            "update": {
              "x": {"signal": "(gaugeR - 4) * cos((datum.deg - trk) * PI / 180 - PI/2)"},
              "y": {"signal": "(gaugeR - 4) * sin((datum.deg - trk) * PI / 180 - PI/2)"},
              "x2": {"signal": "(gaugeR + 1) * cos((datum.deg - trk) * PI / 180 - PI/2)"},
              "y2": {"signal": "(gaugeR + 1) * sin((datum.deg - trk) * PI / 180 - PI/2)"},
              "stroke": {"signal": "datum.label !== '' ? '#98A2B3' : '#69707D'"},
              "strokeWidth": {"signal": "datum.label !== '' ? 2 : 1"}
            }
          }
        },
        {
          "type": "symbol",
          "encode": {
            "update": {
              "x": {"value": 0},
              "y": {"signal": "-(gaugeR + 6)"},
              "shape": {"value": "triangle-down"},
              "size": {"value": 80},
              "fill": {"value": "#E7664C"},
              "angle": {"value": 180}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 0}, "y": {"value": -10},
              "text": {"signal": "format(trk, '.0f') + '°'"},
              "fontSize": {"value": 24}, "fontWeight": {"value": "bold"},
              "align": {"value": "center"}, "baseline": {"value": "middle"},
              "fill": {"value": "#DFE5EF"}, "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 0}, "y": {"value": 14},
              "text": {"value": "HDG"},
              "fontSize": {"value": 11},
              "align": {"value": "center"}, "baseline": {"value": "middle"},
              "fill": {"value": "#69707D"}, "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 0}, "y": {"value": 60},
              "text": {"value": "HEADING"},
              "fontSize": {"value": 11}, "fontWeight": {"value": "bold"},
              "align": {"value": "center"}, "baseline": {"value": "middle"},
              "fill": {"value": "#98A2B3"}, "font": {"value": "monospace"}
            }
          }
        }
      ]
    },

    {
      "type": "group",
      "name": "vsiGauge",
      "encode": {
        "enter": {
          "x": {"value": 740},
          "y": {"value": 115},
          "width": {"value": 120},
          "height": {"value": 340}
        }
      },
      "marks": [
        {
          "type": "rect",
          "encode": {
            "update": {
              "x": {"value": 20}, "y": {"value": 0},
              "width": {"value": 40}, "height": {"value": 280},
              "fill": {"value": "#25262E"},
              "cornerRadius": {"value": 4},
              "stroke": {"value": "#343741"},
              "strokeWidth": {"value": 1}
            }
          }
        },
        {
          "type": "rect",
          "encode": {
            "update": {
              "x": {"value": 22},
              "y": {"signal": "vRate >= 0 ? 140 - min(abs(vRate), 20) / 20 * 138 : 140"},
              "width": {"value": 36},
              "height": {"signal": "min(abs(vRate), 20) / 20 * 138"},
              "fill": {"signal": "vRate >= 0 ? '#54B399' : abs(vRate) > 10 ? '#E7664C' : '#DA8B45'"},
              "cornerRadius": {"value": 2}
            }
          }
        },
        {
          "type": "rule",
          "encode": {
            "update": {
              "x": {"value": 16}, "x2": {"value": 64},
              "y": {"value": 140}, "y2": {"value": 140},
              "stroke": {"value": "#DFE5EF"},
              "strokeWidth": {"value": 1},
              "strokeDash": {"value": [4, 2]}
            }
          }
        },
        {
          "type": "text",
          "from": {"data": "vsi_ticks"},
          "encode": {
            "update": {
              "x": {"value": 14},
              "y": {"signal": "140 - datum.data / 20 * 138"},
              "text": {"signal": "datum.data > 0 ? '+' + datum.data : format(datum.data, '.0f')"},
              "fontSize": {"value": 8},
              "align": {"value": "right"}, "baseline": {"value": "middle"},
              "fill": {"value": "#69707D"}, "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 40}, "y": {"value": 300},
              "text": {"signal": "(vRate >= 0 ? '+' : '') + format(vRate, '.1f')"},
              "fontSize": {"value": 18}, "fontWeight": {"value": "bold"},
              "align": {"value": "center"}, "baseline": {"value": "middle"},
              "fill": {"signal": "vRate >= 0 ? '#54B399' : abs(vRate) > 10 ? '#E7664C' : '#DA8B45'"},
              "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 40}, "y": {"value": 318},
              "text": {"value": "m/s"},
              "fontSize": {"value": 10},
              "align": {"value": "center"}, "baseline": {"value": "middle"},
              "fill": {"value": "#69707D"}, "font": {"value": "monospace"}
            }
          }
        },
        {
          "type": "text",
          "encode": {
            "update": {
              "x": {"value": 40}, "y": {"value": 340},
              "text": {"value": "V/S"},
