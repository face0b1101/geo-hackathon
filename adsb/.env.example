# Elastic Stack
ELASTIC_STACK_VERSION=9.3.1

# Docker — set to . if running from this repo root
DOCKER_HOME=.

# Logstash settings
LS_PIPELINE_WORKERS=2
LS_LOG_LEVEL=info
LS_MONITORING_ENABLED=false
LS_MONITORING_CLUSTER_UUID=

# Logstash API credentials
LS_API_USER=
LS_API_PW=

# Logstash HTTP input credentials
LS_HTTP_USER=
LS_HTTP_PW=

# Elasticsearch — set EITHER cloud OR local credentials
# Cloud
ES_CLOUD_ID=
ES_CLOUD_AUTH=
# Local
ES_HOSTS=https://localhost:9200
ES_USER=
ES_PW=
ES_SSL_VERIFICATION=full

# Elasticsearch endpoint for curl setup commands
ES_URL=

# OpenSky Network API
OPENSKY_API_USER=
OPENSKY_API_PW=
