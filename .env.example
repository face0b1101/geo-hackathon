# Elastic Stack
ELASTIC_STACK_VERSION=9.3.1

# Docker — set to . if running from this repo root
DOCKER_HOME=.

# Logstash settings
LS_PIPELINE_WORKERS=2
LS_LOG_LEVEL=info
LS_MONITORING_ENABLED=false
LS_MONITORING_CLUSTER_UUID=

# Logstash monitoring API credentials (port 9600) — user-chosen, not issued by Elasticsearch
LS_API_USER=logstash
LS_API_PW=changeme

# Elasticsearch — endpoint URL and API key (works with Cloud, Serverless, and start-local)
ES_ENDPOINT=
ES_API_KEY_ID=
ES_API_KEY=
ES_API_KEY_ENCODED=

# Kibana endpoint
KB_ENDPOINT=

# OpenSky Network API
OPENSKY_API_USER=
OPENSKY_API_PW=
