# Elastic Stack
ELASTIC_STACK_VERSION=9.3.1

# Docker — set to . if running from this repo root
DOCKER_HOME=.

# Logstash settings
LS_PIPELINE_WORKERS=2
LS_LOG_LEVEL=info
LS_MONITORING_ENABLED=false
LS_MONITORING_CLUSTER_UUID=

# Centralised Pipeline Management — set to true to fetch pipeline configs
# from Elasticsearch/Kibana instead of local files. Requires pipelines to be
# configured in Kibana > Stack Management > Logstash Pipelines.
LS_CENTRALIZED_MGMT=false

# Logstash monitoring API credentials (port 9600) — user-chosen, not issued by Elasticsearch
LS_API_USER=logstash
LS_API_PW=changeme

# Elasticsearch — endpoint URL and API key (works with Cloud Hosted, Obs Serverless, and start-local)
# The API key needs: cluster manage + manage_security, index CRUD on demos-*/geo.shapes-*/adsb-airports-*,
# and Kibana feature privileges for Saved Objects, Agent Builder, Workflows, Actions,
# Advanced Settings, Stack Alerts, Security Solution, General Cases, Main Observability,
# and Observability Cases. See README.md "Generate an API Key" for the full role descriptor.
ES_ENDPOINT=
ES_API_KEY_ID=
ES_API_KEY=
ES_API_KEY_ENCODED=

# Kibana endpoint
KB_ENDPOINT=

# Kibana space (optional) — deploy all Kibana resources into a named space.
# If set, setup.sh creates the space (Observability solution view) and
# prefixes all Kibana API paths with /s/<space>.
# Leave empty to use the default space.
KB_SPACE=

# OpenSky Network API
OPENSKY_API_USER=
OPENSKY_API_PW=
OPENSKY_API_CLIENT_ID=
OPENSKY_API_CLIENT_SECRET=

# Slack — incoming webhook URL for the daily briefing workflow (optional)
# Create a Slack app with an incoming webhook: https://api.slack.com/messaging/webhooks
# If set, setup.sh creates the Kibana Slack connector automatically.
# If not set, configure the connector manually in Kibana > Stack Management > Connectors.
SLACK_WEBHOOK_URL=

# Slack connector ID — the Kibana connector UUID used in workflow Slack steps.
# This is substituted into workflow YAML at deploy time. If SLACK_WEBHOOK_URL is
# set, setup.sh creates a connector with id d85ca362-fb82-56f6-867c-4ef2c356d912
# by default. Override here if using a different connector.
SLACK_CONNECTOR_ID=d85ca362-fb82-56f6-867c-4ef2c356d912

# GNews — API key for the news search correlation in hijack workflows (optional)
# Sign up at https://gnews.io/register for a free API key (100 req/day).
# Free tier has a 12-hour article delay; paid Essential tier is real-time.
# If not set, the workflow skips the news correlation step gracefully.
GNEWS_API_KEY=

JINA_API=